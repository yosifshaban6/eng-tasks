    <div class="logo-section">
      <h1>EngTasks</h1>
    </div>
    <nav class="nav-links">
      <a
        href="/"
        class="nav-link <%= currentPage === 'tasks' ? 'active' : '' %>"
        >Active Tasks</a
      >
      <a
        href="/archived"
        class="nav-link <%= currentPage === 'archived' ? 'active' : '' %>"
